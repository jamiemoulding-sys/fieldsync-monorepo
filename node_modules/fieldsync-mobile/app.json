{
  "expo": {
    "name": "FieldSync",
    "slug": "fieldsync-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fieldsyncmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FieldSync uses your location while you are working to confirm you are at an assigned site when clocking in or out.",
        "NSLocationAlwaysUsageDescription": "FieldSync uses background location only during an active clocked-in shift to record work travel for your employer.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "FieldSync uses your location during active shifts, including in the background after clock-in, to record work travel and stop tracking after clock-out.",
        "UIBackgroundModes": [
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.zorviatech.fieldsyncmobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.zorviatech.fieldsyncmobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "apiUrl": "https://app.zorviatech.co.uk/api",
      "eas": {
        "projectId": "28d175ee-360d-4c51-b22c-00908ae68cee"
      }
    }
  }
}

{
  "name": "@fieldsync/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared business logic, types, and validation for FieldSync clients and API",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}

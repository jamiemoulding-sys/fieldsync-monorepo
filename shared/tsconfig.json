{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmitOnError": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "index.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "validation/**/*.ts",
    "api/**/*.ts",
    "permissions/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
